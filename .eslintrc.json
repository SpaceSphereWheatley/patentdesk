{
  "root": true,
  "plugins": ["html"],
  "overrides": [
    {
      "files": ["*.html"],
      "env": {
        "browser": true,
        "es2022": true
      },
      "globals": {
        "Chart": "readonly"
      },
      "rules": {
        "no-undef": "error",
        "no-unused-vars": "warn",
        "no-unreachable": "error",
        "no-constant-condition": "error",
        "no-dupe-keys": "error",
        "no-duplicate-case": "error",
        "no-self-assign": "error",
        "no-self-compare": "error",
        "use-isnan": "error",
        "valid-typeof": "error"
      }
    }
  ]
}
